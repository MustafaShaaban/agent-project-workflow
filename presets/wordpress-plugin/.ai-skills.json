{
    "version":  "1.0",
    "install_mode":  "ask",
    "authority":  {
                      "startup":  "project-workflow",
                      "planning":  "spec-kit",
                      "safety":  "conditional-guard-skills",
                      "implementation":  "active-spec-tasks",
                      "optional_executor_skills_may_replace_planning":  false,
                      "owner_override_required":  true
                  },
    "skills":  {
                   "required":  [
                                    {
                                        "name":  "project-workflow",
                                        "install_approved":  true,
                                        "install_command":  "npx -y skills add MustafaShaaban/agent-project-workflow --skill project-workflow --global --agent claude-code --agent codex --copy"
                                    },
                                    {
                                        "name":  "clean-code-guard",
                                        "install_approved":  false,
                                        "install_command":  "npx -y skills add amElnagdy/guard-skills --skill clean-code-guard --global --agent claude-code --agent codex --copy"
                                    },
                                    {
                                        "name":  "test-guard",
                                        "install_approved":  false,
                                        "install_command":  "npx -y skills add amElnagdy/guard-skills --skill test-guard --global --agent claude-code --agent codex --copy"
                                    },
                                    {
                                        "name":  "docs-guard",
                                        "install_approved":  false,
                                        "install_command":  "npx -y skills add amElnagdy/guard-skills --skill docs-guard --global --agent claude-code --agent codex --copy"
                                    },
                                    {
                                        "name":  "wp-guard",
                                        "install_approved":  false,
                                        "install_command":  "npx -y skills add amElnagdy/guard-skills --skill wp-guard --global --agent claude-code --agent codex --copy"
                                    }
                                ],
                   "conditional_required":  [
                                                {
                                                    "name":  "wp-guard",
                                                    "condition":  "wordpress_detected",
                                                    "install_approved":  false
                                                },
                                                {
                                                    "name":  "woo-guard",
                                                    "condition":  "woocommerce_detected",
                                                    "install_approved":  false
                                                }
                                            ],
                   "optional":  [
                                    "wp-plugin-development",
                                    "wp-block-development",
                                    "wp-performance",
                                    "wp-phpstan",
                                    "wp-playground"
                                ]
               }
}
