{
  "version": "1.0",
  "description": "Machine-readable skill configuration for AI agents in this project.",
  "install_mode": "ask",
  "skills": {
    "required": [
      {
        "name": "project-workflow",
        "reason": "Universal project safety, branch guard, progress tracking, and handoff routine.",
        "install_command": "npx -y skills add . --skill project-workflow --global --agent claude-code --agent codex --copy",
        "install_approved": true
      }
    ],
    "conditional_required": [
      {
        "name": "wp-guard",
        "condition": "wordpress_detected",
        "reason": "WordPress-specific safety guard for core, plugins, and themes. Required whenever a WordPress project is detected.",
        "install_command": null,
        "install_approved": false,
        "detection_rules": [
          "wp-config.php exists at project root",
          "wp-content/ directory exists",
          "wp-content/plugins/ exists",
          "wp-content/themes/ exists",
          "wp-login.php exists",
          "style.css contains 'Theme Name:' header",
          "composer.json contains 'roots/bedrock' or 'johnpbloch/wordpress'",
          "package.json contains '@wordpress/' packages"
        ]
      }
    ]
  },
  "detection": {
    "platforms": {
      "github": [
        ".github/ directory exists",
        ".github/workflows/ exists",
        "remote URL contains github.com"
      ],
      "azure-devops": [
        ".azure/ directory exists",
        "azure-pipelines.yml exists",
        "remote URL contains dev.azure.com or visualstudio.com"
      ]
    },
    "project_types": {
      "wordpress": [
        "wp-config.php",
        "wp-content/",
        "wp-content/plugins/",
        "wp-content/themes/",
        "wp-login.php",
        "wp-blog-header.php"
      ],
      "laravel": [
        "artisan",
        "app/Http/Kernel.php",
        "composer.json with laravel/framework"
      ],
      "react": [
        "package.json with react dependency"
      ],
      "vue": [
        "package.json with vue dependency"
      ],
      "svelte": [
        "package.json with svelte dependency",
        "svelte.config.js"
      ],
      "laravel_wp": [
        "artisan AND wp-content/"
      ]
    },
    "ci": {
      "github_actions": [
        ".github/workflows/*.yml"
      ],
      "azure_pipelines": [
        "azure-pipelines.yml",
        ".azure/pipelines/*.yml"
      ],
      "other": [
        "Jenkinsfile",
        ".circleci/",
        ".travis.yml",
        "bitbucket-pipelines.yml"
      ]
    },
    "branching": {
      "git_flow": [
        "develop branch exists",
        "release/* branches exist"
      ],
      "trunk_based": [
        "no develop branch",
        "short-lived feature branches only"
      ],
      "github_flow": [
        "feature branches from main",
        "no develop branch"
      ]
    }
  }
}
